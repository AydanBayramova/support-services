{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "8",
        "author": "Aydan",
        "changes": [
          {
            "createTable": {
              "tableName": "courier_wallets",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "UUID",
                    "constraints": {
                      "primaryKey": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "courier_id",
                    "type": "UUID",
                    "constraints": {
                      "nullable": false,
                      "unique": true
                    }
                  }
                },
                {
                  "column": {
                    "name": "balance",
                    "type": "DECIMAL(19, 2)",
                    "defaultValue": "0.00"
                  }
                },
                {
                  "column": {
                    "name": "total_turnover",
                    "type": "DECIMAL(19, 2)",
                    "defaultValue": "0.00"
                  }
                },
                {
                  "column": {
                    "name": "version",
                    "type": "BIGINT",
                    "defaultValue": "0"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}