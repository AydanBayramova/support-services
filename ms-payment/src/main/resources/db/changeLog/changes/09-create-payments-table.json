{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "9",
        "author": "Aydan",
        "changes": [
          {
            "createTable": {
              "tableName": "payments",
              "columns": [
                {
                  "column": {
                    "name": "id",
